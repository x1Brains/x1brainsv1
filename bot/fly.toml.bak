# fly.toml app configuration file generated for x1brains-bot on 2026-04-25T19:11:00-04:00
#
# See https://fly.io/docs/reference/configuration/ for information about how to use this file.
#

app = 'x1brains-bot'
primary_region = 'iad'

[build]
  dockerfile = 'Dockerfile'

[env]
  PYTHONUNBUFFERED = '1'

[[services]]
  protocol = 'tcp'
  internal_port = 8080
  auto_stop_machines = 'off'
  auto_start_machines = false
  min_machines_running = 1
  ports = []

[[vm]]
  cpu_kind = 'shared'
  cpus = 1
  memory_mb = 256
